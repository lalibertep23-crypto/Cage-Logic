# Normalize line endings on push — prevents null byte reintroduction on rebase
* text=auto eol=lf
*.tsx text eol=lf
*.ts text eol=lf
*.css text eol=lf
*.json text eol=lf
*.md text eol=lf
*.js text eol=lf

# Binary files — do not touch
*.png binary
*.jpg binary
*.jpeg binary
*.avif binary
*.webp binary
*.gif binary
*.ico binary
*.mp4 binary
*.woff binary
*.woff2 binary
